#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Validate commit message format
# Examples:
# feat: add new feature
# fix: resolve bug
# docs: update documentation
# style: format code
# refactor: restructure code
# test: add tests
# chore: maintenance tasks

COMMIT_MSG=$(cat "$1")
COMMIT_MSG_REGEX="^(feat|fix|docs|style|refactor|test|chore|ci|perf|revert)(\(.+\))?!?: .+$"

if ! echo "$COMMIT_MSG" | grep -qE "$COMMIT_MSG_REGEX"; then
  echo "❌ Invalid commit message format"
  echo "✅ Valid format: type(scope)?: message"
  echo ""
  echo "Types: feat, fix, docs, style, refactor, test, chore, ci, perf, revert"
  echo "Scope (optional): feature area in parentheses"
  echo "Message: Concise description of changes"
  echo ""
  echo "Examples:"
  echo "  feat(writing): add new blog post"
  echo "  fix(styles): correct heading alignment"
  echo "  docs: update README with contribution guidelines"
  exit 1
fi
